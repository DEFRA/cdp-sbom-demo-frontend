{
  "name": "cdp-sbom-demo-frontend",
  "version": "0.0.0",
  "description": "CDP Dependency explorer demo",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:client": "NODE_ENV=production webpack",
    "start": "run-p client:watch server:watch",
    "start:debug": "run-p client:watch server:debug",
    "docker:dev": "npm start",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "client:watch": "NODE_ENV=development webpack --watch",
    "git:pre-commit-hook": "npm run security-audit && npm run format:check && npm run lint && npm test",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "pretest": "npm run build:client",
    "test": "TZ=UTC vitest --coverage",
    "security-audit": "npm audit --audit-level=high",
    "server:debug": "node --env-file-if-exists=.env --watch-path=./src --inspect ./src",
    "server:watch": "node --env-file-if-exists=.env --watch-path=./src ./src",
    "prepreview": "npm run build:client",
    "preview": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "imports": {
    "#server/*": "./src/server/*",
    "#config/*": "./src/config/*"
  },
  "overrides": {
    "serialize-javascript": "7.0.3",
    "tmp": "0.2.5"
  },
  "dependencies": {
    "@defra/cdp-auditing": "0.6.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/hapi": "21.4.7",
    "@hapi/inert": "7.1.0",
    "@hapi/scooter": "7.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/yar": "11.0.3",
    "aws-embedded-metrics": "4.2.1",
    "blankie": "5.0.0",
    "convict": "6.2.4",
    "convict-format-with-validator": "6.2.0",
    "cssnano": "7.1.3",
    "cssnano-preset-default": "7.0.11",
    "date-fns": "4.1.0",
    "glob": "13.0.6",
    "global-agent": "3.0.0",
    "govuk-frontend": "5.14.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "history": "5.3.0",
    "ioredis": "5.10.0",
    "lodash": "4.17.23",
    "node-fetch": "3.3.2",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "qs": "6.15.0",
    "semver": "7.7.4",
    "undici": "7.24.4"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@vitest/coverage-v8": "4.1.0",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.1.1",
    "cheerio": "1.2.0",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "13.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "jest-file-snapshot": "0.7.0",
    "jsdom": "29.0.0",
    "neostandard": "0.13.0",
    "npm-run-all": "4.1.5",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.0",
    "prettier": "3.7.4",
    "sass-embedded": "1.97.0",
    "sass-loader": "16.0.7",
    "source-map-loader": "5.0.0",
    "stylelint": "16.26.1",
    "stylelint-config-gds": "2.0.0",
    "terser-webpack-plugin": "5.4.0",
    "vitest": "4.0.16",
    "vitest-fetch-mock": "0.4.5",
    "webpack": "5.105.4",
    "webpack-assets-manifest": "6.5.1",
    "webpack-cli": "7.0.2"
  }
}
